{
  "name": "api-restaurante",
  "version": "1.0.0",
  "description": "API para gerenciar pedidos das mesas de um restaurante",
  "main": "index.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "migrate:make": "tsx node_modules/knex/bin/cli.js migrate:make",
    "migrate:latest": "tsx node_modules/knex/bin/cli.js migrate:latest",
    "migrate:rollback": "tsx node_modules/knex/bin/cli.js migrate:rollback",
    "migrate:list": "tsx node_modules/knex/bin/cli.js migrate:list",
    "migrate:down": "tsx node_modules/knex/bin/cli.js migrate:down",
    "seed:make": "tsx node_modules/knex/bin/cli.js seed:make",
    "seed:run": "tsx node_modules/knex/bin/cli.js seed:run"
  },
  "author": "samuel dantas",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "express": "^4.19.2",
    "knex": "^3.1.0",
    "sqlite3": "^5.1.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.12",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4"
  }
}
